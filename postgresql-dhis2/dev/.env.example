# PostgreSQL Configuration (Analytics Database)
POSTGRES_DB=analytics
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# DHIS2 Database Configuration
DHIS2_DB_NAME=dhis2
DHIS2_DB_USER=dhis
DHIS2_DB_PASSWORD=dhis
DHIS2_DB_PORT=5433

# DHIS2 Application Configuration
DHIS2_PORT=8080
DHIS2_ADMIN_USERNAME=admin
DHIS2_ADMIN_PASSWORD=district

# DHIS2 Traefik Configuration (optional - for reverse proxy setup)
DHIS2_TRAEFIK_ENABLED=true
DHIS2_TRAEFIK_ROUTER=dhis2
DHIS2_TRAEFIK_HOST=dhis2.localhost
DHIS2_TRAEFIK_ENTRYPOINTS=websecure
DHIS2_TRAEFIK_SERVICE=dhis2
DHIS2_TRAEFIK_SERVICE_PORT=8080

# EIP Client Configuration
EIP_CLIENT_PORT=8085
EIP_CLIENT_VERSION=1.0.0-SNAPSHOT
# Package scanning for route discovery (comma-separated)
EIP_APP_SCAN_PACKAGES=com.ozonehis.eip.dhis2
# Disable Spring Boot Actuator HikariCP metrics to avoid version conflicts
SPRING_AUTOCONFIGURE_EXCLUDE=org.springframework.boot.actuate.autoconfigure.metrics.jdbc.DataSourcePoolMetricsAutoConfiguration

# EIP Application Configuration
# These should match your application.properties and are used by the EIP client
EIP_POSTGRESQL_JDBC_URL=jdbc:postgresql://postgresql:5432/analytics
EIP_POSTGRESQL_USERNAME=postgres
EIP_POSTGRESQL_PASSWORD=postgres
EIP_DHIS2_BASE_URL=http://dhis2:8080
EIP_DHIS2_USERNAME=admin
EIP_DHIS2_PASSWORD=district
EIP_DHIS2_MAPPING_FILE=/eip-client/config/dhis2-mappings.yml

# External mapping file (host path mounted into the container)
DHIS2_MAPPING_FILE_HOST=./config/dhis2-mappings.yml

# EIP Route Configuration
# PostgreSQL query cron expression (default: 0 */2 * * * ? = every 2 minutes)
# Examples: 0 */5 * * * ? (every 5 minutes), 0 0 * * * ? (every hour), 0 0 0 * * ? (daily at midnight)
EIP_POSTGRESQL_QUERY_CRON=0 */2 * * * ?
# PostgreSQL query SQL
# Transformation DSL (leave empty for default transformation)
EIP_TRANSFORMATION_DSL=
